                              backgroundColor:
                                grade === "1등급"
                                  ? "#D32F2F"
                                  : grade === "2등급"
                                  ? "#F57C00"
                                  : grade === "3등급"
                                  ? "#FBC02D"
                                  : grade === "4등급"
                                  ? "#7CB342"
                                  : "#388E3C",
