        {/* Bottom - TOP 10 Section */}
        <div className="mt-8">
          <Card className="border-[#E5E7EB] shadow-sm">
            <CardHeader>
              <div className="flex items-center justify-between">
                <CardTitle className="text-xl">전국 TOP 10 후보지</CardTitle>
                <Button
                  variant="outline"
                  onClick={() => navigate("/top-candidates")}
                  className="border-[#2F5D50] text-[#2F5D50] hover:bg-[#2F5D50]/5"
                >
                  전체 보기
                </Button>
              </div>
            </CardHeader>
            <CardContent>
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead className="bg-[#F8FAF8]">
                    <tr>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        순위
                      </th>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        지역
                      </th>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        등급
                      </th>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        AI 점수
                      </th>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        산불 피해도
                      </th>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        재해 위험도
                      </th>
                      <th className="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                        노출도
                      </th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-[#E5E7EB]">
                    {[
                      {
                        rank: 1,
                        location: "경상북도 의성군",
                        grade: "1등급",
                        score: 92.4,
                        fire: 87,
                        disaster: 72,
                        exposure: 65,
                      },
                      {
                        rank: 2,
                        location: "강원도 삼척시",
                        grade: "1등급",
                        score: 91.2,
                        fire: 85,
                        disaster: 78,
                        exposure: 68,
                      },
                      {
                        rank: 3,
                        location: "경상남도 거창군",
                        grade: "1등급",
                        score: 89.8,
                        fire: 82,
                        disaster: 75,
                        exposure: 71,
                      },
                      {
                        rank: 4,
                        location: "전라남도 구례군",
                        grade: "1등급",
                        score: 88.5,
                        fire: 79,
                        disaster: 73,
                        exposure: 69,
                      },
                      {
                        rank: 5,
                        location: "충청북도 제천시",
                        grade: "2등급",
                        score: 86.3,
                        fire: 76,
                        disaster: 70,
                        exposure: 66,
                      },
                      {
                        rank: 6,
                        location: "경상북도 봉화군",
                        grade: "2등급",
