                        fire: 65,
                        disaster: 60,
                        exposure: 56,
                      },
                    ].map((item) => (
                      <tr key={item.rank} className="hover:bg-[#F8FAF8] transition-colors">
                        <td className="px-4 py-3">
                          <div className="flex items-center justify-center w-8 h-8 rounded-full bg-[#2F5D50]/10 text-[#2F5D50] font-semibold">
                            {item.rank}
                          </div>
                        </td>
                        <td className="px-4 py-3 text-sm text-gray-900 font-medium">
                          {item.location}
                        </td>
                        <td className="px-4 py-3">
                          <span
                            className="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium text-white"
                            style={{
                              backgroundColor:
                                item.grade === "1등급"
                                  ? "#D32F2F"
                                  : item.grade === "2등급"
                                  ? "#F57C00"
                                  : "#FBC02D",
                            }}
                          >
                            {item.grade}
                          </span>
                        </td>
                        <td className="px-4 py-3 text-sm font-semibold text-gray-900">
                          {item.score}점
                        </td>
                        <td className="px-4 py-3">
                          <div className="flex items-center space-x-2">
                            <div className="flex-1 bg-gray-200 rounded-full h-2">
                              <div
                                className="bg-[#D32F2F] h-2 rounded-full"
                                style={{ width: `${item.fire}%` }}
                              ></div>
                            </div>
                            <span className="text-xs text-gray-600 w-8">{item.fire}%</span>
                          </div>
                        </td>
                        <td className="px-4 py-3">
                          <div className="flex items-center space-x-2">
                            <div className="flex-1 bg-gray-200 rounded-full h-2">
                              <div
                                className="bg-[#F57C00] h-2 rounded-full"
                                style={{ width: `${item.disaster}%` }}
                              ></div>
                            </div>
                            <span className="text-xs text-gray-600 w-8">{item.disaster}%</span>
                          </div>
                        </td>
                        <td className="px-4 py-3">
                          <div className="flex items-center space-x-2">
                            <div className="flex-1 bg-gray-200 rounded-full h-2">
                              <div
                                className="bg-[#FBC02D] h-2 rounded-full"
                                style={{ width: `${item.exposure}%` }}
                              ></div>
                            </div>
                            <span className="text-xs text-gray-600 w-8">{item.exposure}%</span>
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </CardContent>
          </Card>
        </div>
      </div>
    </div>
  );
}
