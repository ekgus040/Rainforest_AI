                  <div className="flex items-center justify-between mb-3">
                    <span className="text-sm font-medium text-gray-900">적용된 필터</span>
                    <Button
                      variant="ghost"
                      size="sm"
                      onClick={() => {
                        setSelectedRegions(["전국"]);
                        setSelectedYears(["전체"]);
                        setSelectedGrades(["전체"]);
                        setSelectedRisks([]);
                      }}
                      className="text-xs text-[#2F5D50] hover:text-[#2F5D50]/80 h-auto p-0"
                    >
                      전체 초기화
                    </Button>
                  </div>
                  <div className="flex flex-wrap gap-2">
                    {selectedRegions
                      .filter((r) => r !== "전국")
                      .map((region) => (
                        <div
                          key={region}
                          className="inline-flex items-center space-x-1 bg-white border border-[#E5E7EB] rounded px-2 py-1 text-xs"
                        >
                          <span>{region}</span>
                          <button
                            onClick={() =>
                              setSelectedRegions(selectedRegions.filter((r) => r !== region))
                            }
                            className="text-gray-500 hover:text-gray-700"
                          >
                            <X className="h-3 w-3" />
                          </button>
                        </div>
                      ))}
                    {selectedYears
                      .filter((y) => y !== "전체")
                      .map((year) => (
                        <div
                          key={year}
                          className="inline-flex items-center space-x-1 bg-white border border-[#E5E7EB] rounded px-2 py-1 text-xs"
