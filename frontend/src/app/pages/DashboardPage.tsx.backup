                        fire: 71,
                        disaster: 66,
                        exposure: 62,
                      },
                      {
                        rank: 8,
                        location: "전라남도 광양시",
                        grade: "2등급",
                        score: 81.9,
                        fire: 69,
                        disaster: 64,
                        exposure: 60,
                      },
                      {
                        rank: 9,
                        location: "경상남도 함양군",
                        grade: "3등급",
