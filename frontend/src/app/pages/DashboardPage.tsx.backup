            </Card>

            {/* Active Filters Summary */}
            {(selectedRegions.some((r) => r !== "전국") ||
              selectedYears.some((y) => y !== "전체") ||
              selectedGrades.some((g) => g !== "전체") ||
              selectedRisks.length > 0) && (
              <Card className="border-[#2F5D50] bg-[#2F5D50]/5 shadow-sm">
