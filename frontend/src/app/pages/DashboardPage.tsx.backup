                            <X className="h-3 w-3" />
                          </button>
                        </div>
                      ))}
                    {selectedRisks.map((risk) => (
                      <div
                        key={risk}
                        className="inline-flex items-center space-x-1 bg-white border border-[#E5E7EB] rounded px-2 py-1 text-xs"
                      >
                        <span>{risk}</span>
                        <button
                          onClick={() => setSelectedRisks(selectedRisks.filter((r) => r !== risk))}
                          className="text-gray-500 hover:text-gray-700"
