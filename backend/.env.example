PORT=4000

# 행정안전부 생활안전지도(safemap.go.kr) Open API 인증키
# https://www.safemap.go.kr 에서 회원가입 > Open API 신청 후 발급
# 비워두면 mockCandidates.js의 disasterVuln 값을 그대로 사용함
SAFEMAP_API_KEY=

# Gemini API 키 (보고서/이메일 초안 생성용)
# https://aistudio.google.com 에서 발급
# 비워두면 fallback 텍스트(generateFallbackPolicyReport/EmailDraft)를 사용함
GEMINI_API_KEY=
